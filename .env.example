# Alchemy credentials — copy this file to `.env` and fill in real values.
# `.env` is git-ignored (`node_modules/` + `.env` in `.gitignore`); this
# `.env.example` is intentionally safe to commit so collaborators know
# which variables the project expects.
#
# Get your key at https://dashboard.alchemy.com → Account → API Keys.
ALCHEMY_API_KEY=
